              "justifyMode": "center",
              "textMode": "value_and_name"
            }
          }
        }
      }
    },
    "panel-pods-up": {
      "kind": "Panel",
      "spec": {
        "id": 6,
        "title": "App Pods Up",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
