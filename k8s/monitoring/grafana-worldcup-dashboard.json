                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"worldcup\", pod=~\"app-.*\", container=\"app\"}[5m]))",
                      "legendFormat": "app cpu",
                      "range": true
