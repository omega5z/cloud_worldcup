{
  "title": "Worldcup K3s App Overview",
  "uid": "worldcup-k3s-overview",
  "tags": ["worldcup", "k3s", "prometheus"],
  "cursorSync": "Off",
  "liveNow": false,
  "preload": false,
  "editable": true,
  "links": [],
  "variables": [],
  "annotations": [],
  "timeSettings": {
    "from": "now-30m",
    "to": "now",
    "timezone": "browser",
    "autoRefresh": "10s",
    "autoRefreshIntervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "hideTimepicker": false
  },
  "elements": {
    "panel-http-rate": {
      "kind": "Panel",
      "spec": {
        "id": 1,
        "title": "HTTP Request Rate",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "refId": "A",
                  "hidden": false,
                  "datasource": { "type": "prometheus", "uid": "prometheus" },
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "sum(rate(http_requests_total[5m])) by (method, status_code)",
                      "legendFormat": "{{method}} {{status_code}}",
                      "range": true
                    }
                  }
                }
              }
            ],
            "transformations": [],
            "queryOptions": { "hideTimeOverride": false }
          }
        },
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "pluginVersion": "12.0.0",
            "fieldConfig": {
              "defaults": {
                "unit": "reqps",
                "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
              },
              "overrides": []
            },
            "options": {
              "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
              "tooltip": { "mode": "multi", "sort": "desc" }
            }
          }
        }
      }
    },
    "panel-latency": {
      "kind": "Panel",
      "spec": {
        "id": 2,
        "title": "HTTP Latency p95",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "refId": "A",
                  "hidden": false,
                  "datasource": { "type": "prometheus", "uid": "prometheus" },
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
                      "legendFormat": "{{route}} p95",
                      "range": true
                    }
                  }
                }
              }
            ],
            "transformations": [],
            "queryOptions": { "hideTimeOverride": false }
          }
        },
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "pluginVersion": "12.0.0",
            "fieldConfig": {
              "defaults": { "unit": "s" },
              "overrides": []
            },
            "options": {
              "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
              "tooltip": { "mode": "multi", "sort": "desc" }
            }
          }
        }
      }
    },
    "panel-memory": {
      "kind": "Panel",
      "spec": {
        "id": 3,
        "title": "App Memory",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "refId": "A",
                  "hidden": false,
                  "datasource": { "type": "prometheus", "uid": "prometheus" },
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "sum(container_memory_working_set_bytes{namespace=\"worldcup\", pod=~\"app-.*\", container=\"app\"})",
                      "legendFormat": "app memory",
                      "range": true
                    }
                  }
                }
              }
            ],
            "transformations": [],
            "queryOptions": { "hideTimeOverride": false }
          }
        },
        "vizConfig": {
          "kind": "timeseries",
          "spec": {
            "pluginVersion": "12.0.0",
            "fieldConfig": {
              "defaults": { "unit": "bytes" },
              "overrides": []
            },
            "options": {
              "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
              "tooltip": { "mode": "single", "sort": "none" }
            }
          }
        }
      }
    },
    "panel-cpu": {
      "kind": "Panel",
      "spec": {
        "id": 4,
        "title": "App CPU",
        "description": "",
        "links": [],
