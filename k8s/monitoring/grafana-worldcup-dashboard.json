                  "refId": "A",
                  "hidden": false,
                  "datasource": { "type": "prometheus", "uid": "prometheus" },
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "count(up{job=\"app\"} == 1)",
