          }
        }
      }
    },
    "panel-hpa": {
      "kind": "Panel",
      "spec": {
        "id": 5,
        "title": "HPA Replicas",
        "description": "",
        "links": [],
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "refId": "A",
                  "hidden": false,
                  "datasource": { "type": "prometheus", "uid": "prometheus" },
                  "query": {
                    "kind": "DataQuery",
                    "group": "prometheus",
                    "version": "v0",
                    "datasource": { "name": "prometheus" },
                    "spec": {
                      "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"worldcup\", horizontalpodautoscaler=\"app-hpa\"}",
                      "range": true
